generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  routines  Routine[]
}

model Routine {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  answers   String
  result    String
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
}
model Order {
  id        String      @id @default(cuid())
  userId    String?
  name      String
  email     String
  mobile    String
  address   String
  total     Float
  status    String      @default("pending")
  refId     String?
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  name      String
  price     Float
  quantity  Int
}